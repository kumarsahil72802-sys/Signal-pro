# Server Configuration
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/signal_db

# API Keys
BINANCE_API_KEY=your_binance_api_key_here
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key_here

# Rate limit (higher for dashboard polling, tune per deployment)
# Dev default is 2000/15min if unset
# Production default is 300/15min if unset
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000

# Comma-separated allowlist for browser origins.
# Example: https://app.example.com,https://admin.example.com
# Leave empty in local dev.
CORS_ORIGINS=

# Protect write APIs (create/take/miss signal).
# If NODE_ENV=production or this key is set, write auth is enforced.
SIGNAL_WRITE_API_KEY=
# Set true only for trusted local dev environments.
DISABLE_WRITE_AUTH=false

# Signal Engine
# SIGNAL_COINS supports:
# - Comma list: BTCUSDT,ETHUSDT,SOLUSDT
# - TOP mode: TOP50 (top N by market cap mapped to USDT pairs)
# - ALL mode: ALL (all liquid USDT spot pairs from Binance)
SIGNAL_COINS=TOP50
SIGNAL_TOP_COINS=50
SIGNAL_MAX_COINS=120
SIGNAL_MIN_24H_QUOTE_VOLUME_USDT=2000000
SIGNAL_INTERVAL=1h

# Execution quality integration (Binance order-book + spread-aware confidence adjustment)
# true  -> apply execution quality penalty/bonus and hard-block worst liquidity
# false -> skip execution quality influence on signal generation
SIGNAL_USE_EXECUTION_QUALITY=true
