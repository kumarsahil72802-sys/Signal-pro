# Server Configuration
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/signal_db

# API Keys
BINANCE_API_KEY=your_binance_api_key_here
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Rate limit (higher for dashboard polling, tune per deployment)
# Dev default is 2000/15min if unset
# Production default is 300/15min if unset
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000

# Comma-separated allowlist for browser origins.
# Example: https://app.example.com,https://admin.example.com
# Leave empty in local dev.
CORS_ORIGINS=

# Signal Engine
# SIGNAL_COINS supports:
# - Comma list: BTCUSDT,ETHUSDT,SOLUSDT
# - TOP mode: TOP50 (top N by market cap mapped to USDT pairs)
# - ALL mode: ALL (all liquid USDT spot pairs from Binance)
#
# SIGNAL_PROFILE presets:
# - STRICT     : fewer, higher-quality signals
# - BALANCED   : recommended (better frequency + quality)
# - AGGRESSIVE : more signals, higher noise risk
SIGNAL_PROFILE=BALANCED

# Optional tuning overrides (empty = follow profile preset)
# SIGNAL_THRESHOLD_OFFSET example: -6 lowers effective confidence gate
SIGNAL_THRESHOLD_OFFSET=
# SIGNAL_COOLDOWN_HOURS example: 1, 0.5, 2
SIGNAL_COOLDOWN_HOURS=
# Allow signals in ranging market when breakout trigger exists
SIGNAL_ALLOW_RANGING_BREAKOUTS=
# BTC Strong Bearish BUY hard-block toggle
SIGNAL_USE_BTC_HARD_BLOCK=
# 4H opposite-trend hard block toggle
SIGNAL_USE_4H_HARD_FILTER=
# AI reject handling mode: HARD | SOFT | OFF
SIGNAL_AI_REJECT_MODE=
# AI pipeline mode:
# ADVISORY -> AI never blocks publishing
# GATED    -> reserved for future use (current behavior remains advisory)
SIGNAL_AI_MODE=ADVISORY
# AI enrichment timing:
# SYNC  -> enrich before save/publish
# ASYNC -> skip sync enrichment in generator path
SIGNAL_AI_ENRICHMENT_TIMING=ASYNC
# Retry policy for Grok enrichment requests
SIGNAL_AI_RETRY_COUNT=0
SIGNAL_AI_RETRY_BACKOFF_MS=1500
SIGNAL_AI_TIMEOUT_MS=60000
# Run Grok enrichment only for machine-generated signals with confidence >= this threshold
SIGNAL_AI_TRIGGER_MIN_CONFIDENCE=60
# On Grok 429, skip Grok calls for this duration (ms) while machine signals continue
SIGNAL_AI_429_COOLDOWN_MS=900000
# Trigger tuning
# Minimum absolute EMA slope (%) needed for trigger checks
SIGNAL_TRIGGER_SLOPE_MIN_ABS=
# Price-to-EMA proximity threshold (%)
SIGNAL_EMA_PROXIMITY_PCT=
# EMA test threshold (%) for pullback trigger
SIGNAL_EMA_TEST_PCT=
# Require candle rejection pattern for EMA_ZONE trigger
SIGNAL_REQUIRE_ZONE_REJECTION=
# Ranging regime classifier tuning
SIGNAL_RANGING_SLOPE_MAX=
SIGNAL_RANGING_BB_MAX=

SIGNAL_COINS=TOP50
SIGNAL_TOP_COINS=50
SIGNAL_MAX_COINS=120
SIGNAL_MIN_24H_QUOTE_VOLUME_USDT=2000000
SIGNAL_INTERVAL=1h

# Execution quality integration (Binance order-book + spread-aware confidence adjustment)
# true  -> apply execution quality penalty/bonus and hard-block worst liquidity
# false -> skip execution quality influence on signal generation
SIGNAL_USE_EXECUTION_QUALITY=true
# true  -> include Binance futures context (funding/OI/top-trader ratios) in confidence
SIGNAL_USE_FUTURES_CONTEXT=true
# true  -> include Binance websocket realtime microstructure in confidence
SIGNAL_USE_REALTIME_CONTEXT=true

# Macro layer (DXY + S&P500)
# Snapshot cache duration in minutes
MACRO_CACHE_TTL_MINUTES=60
# Lookback window (daily candles) used for trend classification
MACRO_LOOKBACK_DAYS=10
# Absolute % move threshold considered a strong macro trend
MACRO_STRONG_TREND_PCT=0.35

# Order book / liquidity layer
# Binance depth levels fetched per symbol (use 100 for stable latency/coverage)
SIGNAL_DEPTH_LIMIT=100
# Analyze bids/asks within this % range around current price
SIGNAL_ORDERBOOK_RANGE_PCT=1.5
# "Near entry" zone used for wall pressure concentration checks
SIGNAL_ORDERBOOK_NEAR_RANGE_PCT=0.5
# Max level volume must exceed avg level volume by this multiplier to be treated as whale wall
SIGNAL_WHALE_WALL_MULTIPLIER=2.5
# Additional dominance multiplier for side-level hard liquidity blocks
SIGNAL_WHALE_WALL_DOMINANCE=1.6
# Liquidity reject handling: HARD | SOFT | OFF
SIGNAL_LIQUIDITY_REJECT_MODE=SOFT

# Monitoring / reconciliation
SIGNAL_CHECK_INTERVAL_MS=60000
SIGNAL_MONITOR_INTERVAL_MS=60000
SIGNAL_RECONCILE_MIN_INTERVAL_MS=300000
SIGNAL_VALIDITY_HOURS=8
SIGNAL_RECONCILE_ON_MONITOR=true
SIGNAL_REPLAY_INTERVAL=1m
SIGNAL_REPLAY_KLINE_LIMIT=1000
SIGNAL_REPLAY_MAX_GAP_HOURS=72
SIGNAL_REPLAY_RETRY_COUNT=2
SIGNAL_REPLAY_AMBIGUITY_POLICY=CONSERVATIVE
SIGNAL_MONITOR_CHECKPOINT_KEY=signal_monitor_checkpoint_ms

# Winrate + adaptive learning
SIGNAL_MACHINE_VERSION=winrate_v1
SIGNAL_WINRATE_BASELINE_WINDOW=200
SIGNAL_WINRATE_BASELINE_MIN_SAMPLE=120
SIGNAL_SEGMENT_MIN_SAMPLE=10
SIGNAL_SEGMENT_COOLDOWN_MINUTES=180
SIGNAL_SENTIMENT_NEWS_LIMIT=12
SIGNAL_SENTIMENT_ENABLED=true
AI_LEARNING_WINDOW=300
AI_LEARNING_CACHE_TTL_MS=120000

# Signal supply control
SIGNAL_MIN_SIGNALS_PER_DAY=1
SIGNAL_SUPPLY_LOOKBACK_HOURS=24
SIGNAL_SUPPLY_ADJUST_STEP=1
SIGNAL_SUPPLY_MIN_BASE_THRESHOLD=56

# NVIDIA enrichment (optional)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Deployment hardening
NODE_ENV=development
# For reverse proxies (Nginx/Cloudflare). Example: true or 1
TRUST_PROXY=
